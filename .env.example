# ──────────────────────────────────────────────
# Salotto — Environment Configuration
# Copy this file to backend/.env for local dev
# ──────────────────────────────────────────────

# Database (PostgreSQL)
DATABASE_URL=postgres://salotto:salotto_dev_password@localhost:5432/salotto

# Redis
REDIS_URL=redis://127.0.0.1:6379

# S3 / MinIO
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=salotto
S3_REGION=us-east-1

# JWT Authentication
JWT_SECRET=change-me-to-a-real-secret-in-production-must-be-at-least-32-chars-long
JWT_ACCESS_TTL_SECS=900       # 15 minutes
JWT_REFRESH_TTL_SECS=604800   # 7 days

# LiveKit (WebRTC media server)
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Server
HOST=0.0.0.0
PORT=8080

# Logging (tracing filter)
RUST_LOG=salotto_backend=debug,tower_http=debug
